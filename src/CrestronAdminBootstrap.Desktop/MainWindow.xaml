                                                                        <DataTrigger Binding="{Binding Status}" Value="OK">
                                                                            <Setter Property="Foreground" Value="#4CAF50" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                            <Setter Property="Foreground" Value="#FF5252" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                            <Setter Property="Foreground" Value="#FF9800" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                   Margin="8,0,8,0" VerticalAlignment="Top" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Timestamp}"
                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                   FontSize="11" VerticalAlignment="Top" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="3"
                               Text="{Binding PerDeviceSummary}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,8,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <GroupBox Header="Credentials" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="360" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Default username"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,8" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding SettingsDefaultUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Default password"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,8" />
                                    <PasswordBox x:Name="SettingsDefaultPasswordBox"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Text="{Binding SettingsSavedPasswordStatus}"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Storage" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Settings file"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,8" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SettingsPath}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <Button Grid.Column="2"
                                            Content="Open Folder"
                                            Command="{Binding OpenSettingsFolderCommand}"
                                            Margin="10,0,0,8" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Output folder"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding DataRoot}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Content="Open Folder"
                                            Command="{Binding OpenOutputFolderCommand}"
                                            Margin="10,0,0,0" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Most Used Subnets" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="One CIDR per line."
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,0,8" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding SettingsMostUsedSubnets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Height="170"
                                             FontFamily="Consolas" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Appearance" Margin="0">
                                <CheckBox Content="Dark mode"
                                          IsChecked="{Binding SettingsDarkMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </GroupBox>

                            <GroupBox Header="Legacy Tools" Margin="0,10,0,0">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="Launch Legacy GUI"
                                            Command="{Binding LaunchLegacyGuiCommand}"
                                            Margin="12,0,0,0" />
                                    <TextBlock Text="Fallback access while the compiled shell finishes taking over."
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,10,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <Button Content="Save Settings"
                                        Command="{Binding SaveSettingsCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Clear Saved Password"
                                        Command="{Binding ClearSettingsPasswordCommand}"
                                        Margin="0,0,8,0" />
                                <Button Content="Reload"
                                        Command="{Binding ReloadSettingsCommand}"
                                        Margin="0,0,8,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding SettingsStatus}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
