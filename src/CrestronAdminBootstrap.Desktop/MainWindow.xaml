<Window x:Class="CrestronAdminBootstrap.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:CrestronAdminBootstrap.Desktop.Converters"
        mc:Ignorable="d"
        Title="Crestron Admin Bootstrap"
        Height="760"
        Width="1220"
        MinHeight="650"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#202124">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#202124" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2B2D31" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#32353B" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#50545C" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AEB4BE" />
        <SolidColorBrush x:Key="ProgressActiveBrush" Color="#FF4444" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2D7DD2" />
        <SolidColorBrush x:Key="AccentBrushHover" Color="#3D8EE4" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1F22" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#616671" />
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#363941" />
        <SolidColorBrush x:Key="GridRowBrush" Color="#2B2D31" />
        <SolidColorBrush x:Key="GridAltRowBrush" Color="#26282D" />
        <SolidColorBrush x:Key="GridSelectedBrush" Color="#245B94" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1F22" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#32353B" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F3F5F7" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D7DD2" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F3F5F7" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#AEB4BE" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3D45" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrushHover}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>
                            <!-- outer border -->
                            <Border x:Name="OuterBorder"
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3" />
                            <!-- selected-item display (non-editable) -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <!-- editable text box (IsEditable=True) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     BorderThickness="0"
                                     Focusable="True"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <!-- dropdown arrow -->
                            <Path x:Name="Arrow"
                                  Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{DynamicResource MutedTextBrush}" />
                            <!-- transparent toggle button over entire control -->
                            <ToggleButton Grid.ColumnSpan="2"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- dropdown popup -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="{DynamicResource InputBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1" />
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="EditStates">
                                    <VisualState x:Name="Editable">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="PART_EditableTextBox">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility"
                                                                           Storyboard.TargetName="ContentSite">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Hidden}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Uneditable" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Arrow" Property="Fill"
                                        Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PanelAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource PanelAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="Panel.ZIndex" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource PanelBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="{DynamicResource GridRowBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRowBrush}" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="6,2" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridSelectedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/CrestronBootstrap1.png"
                           Width="48"
                           Height="48"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Crestron Admin Bootstrap"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <Border Background="{DynamicResource AppBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    Padding="6,2"
                                    Margin="10,1,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding AppVersion}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="11" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <ProgressBar Grid.Column="1"
                             Width="160"
                             Height="8"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Border Grid.Column="2"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="10,5"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CredentialsStatus}"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </Border>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource PanelBrush}"
                   BorderBrush="{DynamicResource BorderBrushDark}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextBrush}" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="10"
                    SelectedIndex="{Binding MainTabIndex, Mode=TwoWay}">
            <TabItem Header="Full Workflow">
                <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Full Workflow"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Runs Scan, Provision, Blanket Settings, Per Device, and Reboot in sequence."
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Start Workflow"
                                    Command="{Binding StartWorkflowCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,0,0,0" />
                            <Button Grid.Column="2"
                                    Content="{Binding WorkflowContinueText}"
                                    Command="{Binding ContinueWorkflowCommand}"
                                    Margin="8,0,0,0" />
                            <Button Grid.Column="3"
                                    Content="Cancel"
                                    Command="{Binding CancelWorkflowCommand}"
                                    Margin="8,0,0,0" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WorkflowSteps}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Number}"
                                                Width="54"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Step"
                                                Binding="{Binding Name}"
                                                Width="170"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="State"
                                                Binding="{Binding State}"
                                                Width="120"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description}"
                                                Width="310"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Detail"
                                                Binding="{Binding Detail}"
                                                Width="*"
                                                MinWidth="360"
                                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Margin="0,8,0,0">
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Cancel"
                                        Command="{Binding CancelWorkflowCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsWorkflowRebootWaiting, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WorkflowRebootCountdown}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Skip Wait"
                                        Command="{Binding SkipWorkflowRebootWaitCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding WorkflowStatus}"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Scan">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="310" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Subnets (CIDR)">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Select subnet(s) to scan. Defaults come from gui-settings.json or subnets.txt."
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewSubnet, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="Add"
                                            Command="{Binding AddSubnetCommand}"
                                            Margin="8,0,0,0" />
                                </Grid>
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <Button Content="Select All"
                                            Command="{Binding SelectAllSubnetsCommand}"
                                            Margin="0,0,4,0" />
                                    <Button Content="Deselect All"
                                            Command="{Binding DeselectAllSubnetsCommand}"
                                            Margin="4,0,0,0" />
                                </UniformGrid>
                                <TextBlock Text="{Binding SelectedSubnetSummary}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="0,8,0,0" />
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Subnets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Cidr}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0,3" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </GroupBox>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="Start Scan"
                                        Command="{Binding StartScanCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Cancel"
                                        Command="{Binding CancelScanCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding ScanResults}">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Sel"
                                                        Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="52"
                                                        MinWidth="52" />
                                <DataGridTextColumn Header="IP"
                                                    Binding="{Binding IP}"
                                                    Width="150"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="Matched Signature"
                                                    Binding="{Binding MatchedSig}"
                                                    Width="*"
                                                    MinWidth="240"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="Scanned At"
                                                    Binding="{Binding ScannedAt}"
                                                    Width="190"
                                                    IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding ScanSummary}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,8,0,0" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Provision">
                <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Provision Selected"
                                    Command="{Binding ProvisionSelectedCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Grid.Column="1"
                                    Content="Reboot Selected"
                                    Command="{Binding RebootSelectedProvisionCommand}"
                                    Margin="8,0,0,0" />
                            <Button Grid.Column="2"
                                    Content="Reload from Scan"
                                    Command="{Binding LoadProvisionFromScanCommand}"
                                    Margin="8,0,0,0" />
                            <Button Grid.Column="3"
                                    Content="Select All"
                                    Command="{Binding SelectAllProvisionCommand}"
                                    Margin="8,0,0,0" />
                            <Button Grid.Column="4"
                                    Content="Deselect All"
                                    Command="{Binding DeselectAllProvisionCommand}"
                                    Margin="8,0,0,0" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1">
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Cancel"
                                        Command="{Binding CancelScanCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsWorkflowRebootWaiting, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WorkflowRebootCountdown}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Skip Wait"
                                        Command="{Binding SkipWorkflowRebootWaitCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ProvisionRows}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Sel"
                                                    Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="52" />
                            <DataGridTextColumn Header="IP"
                                                Binding="{Binding IP}"
                                                Width="160"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="120"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Success"
                                                Binding="{Binding Success}"
                                                Width="110"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Response"
                                                Binding="{Binding Response}"
                                                Width="*"
                                                MinWidth="360"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding Timestamp}"
                                                Width="170"
                                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ProvisionSummary}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,8,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Blanket Settings">
                <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <WrapPanel>
                            <GroupBox Header="NTP / Time Zone" Width="360" MinHeight="180">
                                <StackPanel>
                                    <CheckBox Content="Apply NTP / Time Zone"
                                              IsChecked="{Binding ApplyNtp, Mode=TwoWay}" />
                                    <Grid Margin="18,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Server" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding NtpServer, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="1"
                                                   Text="Time Zone"
                                                   VerticalAlignment="Center"
                                                   Margin="0,8,0,0" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  ItemsSource="{Binding TimeZoneOptions}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Code"
                                                  SelectedValue="{Binding TimeZoneCode, Mode=TwoWay}"
                                                  Margin="0,8,0,0" />
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Cloud" Width="260" MinHeight="180">
                                <StackPanel>
                                    <CheckBox Content="Apply XiO Cloud"
                                              IsChecked="{Binding ApplyCloud, Mode=TwoWay}" />
                                    <CheckBox Content="Enable XiO Cloud"
                                              IsChecked="{Binding CloudEnabled, Mode=TwoWay}"
                                              Margin="18,8,0,0" />
                                    <Separator Margin="0,14,0,12" />
                                    <CheckBox Content="Apply Fusion"
                                              IsChecked="{Binding ApplyFusion, Mode=TwoWay}" />
                                    <CheckBox Content="Enable Fusion"
                                              IsChecked="{Binding FusionEnabled, Mode=TwoWay}"
                                              Margin="18,8,0,0" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Auto Update / AV Framework" Width="310" MinHeight="180">
                                <StackPanel>
                                    <CheckBox Content="Apply Auto-Update"
                                              IsChecked="{Binding ApplyAutoUpdate, Mode=TwoWay}" />
                                    <CheckBox Content="Enable Auto-Update"
                                              IsChecked="{Binding AutoUpdateEnabled, Mode=TwoWay}"
                                              Margin="18,8,0,0" />
                                    <Separator Margin="0,14,0,12" />
                                    <CheckBox Content="Apply AV Framework"
                                              IsChecked="{Binding ApplyAvFramework, Mode=TwoWay}" />
                                    <CheckBox Content="Enable AV Framework"
                                              IsChecked="{Binding AvFrameworkEnabled, Mode=TwoWay}"
                                              Margin="18,8,0,0" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Display" Width="380" MinHeight="180">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.ColumnSpan="2"
                                              Content="Apply display settings"
                                              IsChecked="{Binding ApplyDisplay, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="1"
                                               Text="Auto Brightness"
                                               VerticalAlignment="Center"
                                               Margin="18,8,0,0" />
                                    <CheckBox Grid.Row="1"
                                              Grid.Column="1"
                                              Content="Enabled"
                                              IsChecked="{Binding AutoBrightnessEnabled, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="2"
                                               Text="Brightness"
                                               VerticalAlignment="Center"
                                               Margin="18,8,0,0" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3"
                                               Text="Screensaver"
                                               VerticalAlignment="Center"
                                               Margin="18,8,0,0" />
                                    <CheckBox Grid.Row="3"
                                              Grid.Column="1"
                                              Content="Enabled"
                                              IsChecked="{Binding ScreensaverEnabled, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="4"
                                               Text="Standby / Toolbar"
                                               VerticalAlignment="Center"
                                               Margin="18,8,0,0" />
                                    <StackPanel Grid.Row="4"
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <TextBox Width="70"
                                                 Text="{Binding StandbyTimeout, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Content="Toolbar"
                                                  IsChecked="{Binding ToolbarEnabled, Mode=TwoWay}"
                                                  Margin="12,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="AV Settings" Width="560" MinHeight="180">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <CheckBox Content="Apply Input HDCP"
                                              IsChecked="{Binding ApplyInputHdcp, Mode=TwoWay}" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding InputHdcpOptions}"
                                              SelectedItem="{Binding InputHdcpMode, Mode=TwoWay}" />

                                    <CheckBox Grid.Row="1"
                                              Content="Apply Output HDCP"
                                              IsChecked="{Binding ApplyOutputHdcp, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              ItemsSource="{Binding OutputHdcpOptions}"
                                              SelectedItem="{Binding OutputHdcpMode, Mode=TwoWay}"
                                              Margin="0,8,0,0" />

                                    <CheckBox Grid.Row="2"
                                              Content="Apply Output Resolution"
                                              IsChecked="{Binding ApplyOutputResolution, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              ItemsSource="{Binding OutputResolutionOptions}"
                                              SelectedItem="{Binding OutputResolution, Mode=TwoWay}"
                                              Margin="0,8,0,0" />

                                    <CheckBox Grid.Row="3"
                                              Content="Apply Global EDID"
                                              IsChecked="{Binding ApplyGlobalEdid, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                    <ComboBox Grid.Row="3"
                                              Grid.Column="1"
                                              ItemsSource="{Binding GlobalEdidNameOptions}"
                                              Text="{Binding GlobalEdidName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="2"
                                               Text="Type"
                                               VerticalAlignment="Center"
                                               Margin="12,8,6,0" />
                                    <ComboBox Grid.Row="3"
                                              Grid.Column="3"
                                              ItemsSource="{Binding GlobalEdidTypeOptions}"
                                              SelectedItem="{Binding GlobalEdidType, Mode=TwoWay}"
                                              Margin="0,8,0,0" />
                                </Grid>
                            </GroupBox>
                        </WrapPanel>
                    </ScrollViewer>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel>
                                <TextBlock Text="Devices"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox Width="280"
                                         Text="{Binding BlanketDeviceInput, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Enter one or more IP addresses separated by spaces, commas, or new lines." />
                                <Button Content="Add Devices"
                                        Command="{Binding AddBlanketDevicesCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Scan &amp; Load"
                                        Command="{Binding ScanAndLoadBlanketCommand}"
                                        Margin="8,0,0,0"
                                        ToolTip="Scans selected subnets for all reachable Crestron/AirMedia devices, then loads them here." />
                                <Button Content="Load First-Boot Scan"
                                        Command="{Binding LoadBlanketFromScanCommand}"
                                        Margin="8,0,0,0"
                                        ToolTip="Loads results from the provisioning Scan tab, which only finds first-boot devices." />
                                <Button Content="Reload from Provision"
                                        Command="{Binding LoadBlanketFromProvisionCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Clear Devices"
                                        Command="{Binding ClearBlanketDevicesCommand}"
                                        Margin="8,0,0,0" />
                            </WrapPanel>

                            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                <Button Content="Apply to Selected"
                                        Command="{Binding ApplyBlanketSettingsCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="{Binding WorkflowContinueText}"
                                        Command="{Binding ContinueWorkflowCommand}"
                                        Visibility="{Binding IsWorkflowWaitingOnBlanket, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="8,0,0,0" />
                                <Button Content="Fetch Capabilities"
                                        Command="{Binding FetchBlanketCapabilitiesCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Reboot Selected"
                                        Command="{Binding RebootSelectedBlanketCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Select All"
                                        Command="{Binding SelectAllBlanketCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Deselect All"
                                        Command="{Binding DeselectAllBlanketCommand}"
                                        Margin="8,0,0,0" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1">
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Cancel"
                                        Command="{Binding CancelScanCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsWorkflowRebootWaiting, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WorkflowRebootCountdown}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Skip Wait"
                                        Command="{Binding SkipWorkflowRebootWaitCommand}"
                                        Margin="12,0,0,0" />
                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             IsIndeterminate="True"
                                             Height="10"
                                             Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding BlanketRows}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Sel"
                                                    Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="52" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="150" IsReadOnly="True" />
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="190" IsReadOnly="True" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding CurrentDeviceMode}" Width="105" IsReadOnly="True" />
                            <DataGridTextColumn Header="AV API" Binding="{Binding AvApiFamily}" Width="95" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="AV?" Binding="{Binding SupportsAvSettings}" Width="65" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="EDID?" Binding="{Binding SupportsGlobalEdid}" Width="70" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="NTP?" Binding="{Binding SupportsNtp}" Width="70" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Cloud?" Binding="{Binding SupportsCloud}" Width="80" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Fusion?" Binding="{Binding SupportsFusion}" Width="80" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Auto?" Binding="{Binding SupportsAutoUpdate}" Width="75" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Display?" Binding="{Binding SupportsDisplaySettings}" Width="85" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Toolbar?" Binding="{Binding SupportsToolbarSettings}" Width="85" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="AVF?" Binding="{Binding SupportsAvFrameworkSettings}" Width="70" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Fetched?" Binding="{Binding CapabilitiesFetched}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status" Binding="{Binding DisplayStatus}" Width="120" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Reboot?" Binding="{Binding NeedsReboot}" Width="85" IsReadOnly="True" />
                            <DataGridTextColumn Header="Result" Binding="{Binding ApplySummary}" Width="160" MinWidth="120" IsReadOnly="True" />
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="4" Header="Apply Results" Margin="0,8,0,0"
                              Visibility="{Binding BlanketRows.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding BlanketRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrushDark}"
                                                BorderThickness="0,0,0,1" Padding="6,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Working">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="145" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding IP}"
                                                           FontWeight="SemiBold" VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayStatus}"
                                                           VerticalAlignment="Top">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="OK">
                                                                    <Setter Property="Foreground" Value="#4CAF50" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#FF5252" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Foreground" Value="#FF9800" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           Margin="8,0,8,0" VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="3" Text="{Binding Timestamp}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="11" VerticalAlignment="Top" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>

                    <TextBlock Grid.Row="5"
                               Text="{Binding BlanketSummary}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,8,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Per Device">
                <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel>
                                <TextBlock Text="Devices"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox Width="280"
                                         Text="{Binding PerDeviceInput, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Enter one or more IP addresses separated by spaces, commas, or new lines." />
                                <Button Content="Add Devices"
                                        Command="{Binding AddPerDeviceDevicesCommand}"
                                        Margin="8,0,0,0" />
                                <Button Content="Scan &amp; Load"
                                        Command="{Binding ScanAndLoadPerDeviceCommand}"
                                        Margin="8,0,0,0"
                                        ToolTip="Scans selected subnets for all reachable Crestron/AirMedia devices, then loads them here." />
